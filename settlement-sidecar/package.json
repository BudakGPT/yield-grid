{
  "name": "yieldgrid-settlement-sidecar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chain-facing settlement sidecar: owns custodial keys and all Soroban escrow calls",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "check": "tsc --noEmit",
    "test": "tsx --test src/*.test.ts",
    "deploy": "tsx scripts/deploy.ts",
    "seed": "tsx scripts/seed.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^16.0.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3"
  }
}
