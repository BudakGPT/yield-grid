# ===== YieldGrid environment (copy to .env per service, then fill in) =====
# Secrets live in the backend only. The frontend gets NEXT_PUBLIC_* values only.

# --- backend: core ---
SERVER_PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:5432/yieldgrid
DATABASE_USER=yieldgrid
DATABASE_PASSWORD=
KEY_ENCRYPTION_SECRET=            # encrypts stellar_secret_enc at rest

# --- backend: Stellar / Soroban ---
STELLAR_NETWORK=testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
ESCROW_CONTRACT_ID=              # set after contract deploy
YGIDR_TOKEN_ADDRESS=             # SAC address of the YGIDR test token
YGIDR_ISSUER_PUBLIC=             # issuer account public key
PLATFORM_ADMIN_SECRET=           # admin (settlement) keypair secret; escrow release signer

# --- backend: grading (VLM) ---
VLM_API_KEY=
VLM_MODEL=claude-opus-4-8

# --- backend: IPFS (Pinata) ---
PINATA_JWT=
PINATA_GATEWAY=

# --- frontend (public, safe to expose) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_STELLAR_EXPLORER_BASE=https://stellar.expert/explorer/testnet
