# Backend
PORT=8083
DB_URL=jdbc:postgresql://localhost:5432/yieldgrid
DB_USERNAME=yieldgrid
DB_PASSWORD=
# Supabase on IPv4 networks: use its Session Pooler URL (port 5432) and postgres.PROJECT_REF username.
DB_CONNECTION_TIMEOUT_MS=10000
DB_VALIDATION_TIMEOUT_MS=3000
DB_INITIALIZATION_FAIL_TIMEOUT_MS=10000
DB_POOL_MAX_SIZE=6
DB_POOL_MIN_IDLE=1
DB_IDLE_TIMEOUT_MS=300000
DB_MAX_LIFETIME_MS=1500000
DB_KEEPALIVE_TIME_MS=120000
DB_QUERY_TIMEOUT_MS=10000
JPA_SHOW_SQL=false
# Development-only defaults; replace both with strong random Base64 values outside local development.
JWT_SECRET=ZmFybWxlZGdlci15aWVsZGdyaWQtZGV2LXNlY3JldC1rZXktMzItYnl0ZXMtbWluaW11bQ==
KEY_ENCRYPTION_SECRET=eWllbGRncmlkLWRldi1lbmNyeXB0aW9uLXNlY3JldA==
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=uploads
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AUTH_TIMEOUT=20s
# Existing Supabase accounts in this comma-separated allowlist receive the ADMIN role on login.
ADMIN_EMAILS=
GRADING_MODE=openrouter
DEMO_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=60s
OPENROUTER_MAX_TOKENS=700
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=YieldGrid
PINATA_JWT=
PINATA_BASE_URL=https://api.pinata.cloud
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
PINATA_TIMEOUT=30s

# Backend to settlement sidecar
SIDECAR_ENABLED=false
SIDECAR_URL=http://localhost:8090
# Must match SIDECAR_TOKEN in settlement-sidecar/.env.
SIDECAR_TOKEN=replace-with-a-long-internal-token
SIDECAR_TIMEOUT=120s

# Frontend public configuration
NEXT_PUBLIC_API_URL=http://localhost:8083
NEXT_PUBLIC_WS_URL=ws://localhost:8083/ws
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_ENABLED=false

# Sidecar network
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org
YGIDR_CODE=YGIDR

# Sidecar singletons generated by npm run deploy
