# ============================================================
# YieldGrid backend (Spring Boot)  --  copy to .env and fill in.
# Loaded by application.properties via spring.config.import (.env + ../.env).
# Frontend vars:  frontend/.env.local     (see frontend/.env.example)
# Chain/sidecar vars:  settlement-sidecar/.env  (see its .env.example)
# ============================================================

# --- Server ---
PORT=8083

# --- Database ---
# Local default is an in-memory H2 if DB_URL is unset. Example points at Postgres.
DB_URL=jdbc:postgresql://localhost:5432/yieldgrid
DB_USERNAME=yieldgrid
DB_PASSWORD=
# Supabase on IPv4 networks: use its Session Pooler URL (port 5432) and postgres.PROJECT_REF username.
DB_CONNECTION_TIMEOUT_MS=10000
DB_VALIDATION_TIMEOUT_MS=3000
DB_INITIALIZATION_FAIL_TIMEOUT_MS=10000
DB_POOL_MAX_SIZE=6
DB_POOL_MIN_IDLE=1
DB_IDLE_TIMEOUT_MS=300000
DB_MAX_LIFETIME_MS=1500000
DB_KEEPALIVE_TIME_MS=120000
DB_QUERY_TIMEOUT_MS=10000
JPA_SHOW_SQL=false

# --- Security ---
# Dev-only defaults below; replace both with strong random Base64 values outside local dev.
JWT_SECRET=ZmFybWxlZGdlci15aWVsZGdyaWQtZGV2LXNlY3JldC1rZXktMzItYnl0ZXMtbWluaW11bQ==
KEY_ENCRYPTION_SECRET=eWllbGRncmlkLWRldi1lbmNyeXB0aW9uLXNlY3JldA==
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# --- Supabase auth ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AUTH_TIMEOUT=20s
# Existing Supabase accounts in this comma-separated allowlist receive the ADMIN role on login.
ADMIN_EMAILS=

# --- Grading (OpenRouter VLM) ---
# rehearsal = disclosed cache fallback; openrouter = live VLM (needs OPENROUTER_API_KEY).
GRADING_MODE=rehearsal
DEMO_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=60s
OPENROUTER_MAX_TOKENS=700
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_NAME=YieldGrid

# --- Storage / IPFS (Pinata) ---
UPLOAD_DIR=uploads
PINATA_JWT=
PINATA_BASE_URL=https://api.pinata.cloud
PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
PINATA_TIMEOUT=30s

# --- Settlement sidecar link (backend -> sidecar) ---
# SIDECAR_TOKEN must match settlement-sidecar/.env. Only used when SIDECAR_ENABLED=true.
SIDECAR_ENABLED=false
SIDECAR_URL=http://localhost:8090
SIDECAR_TOKEN=replace-with-a-long-internal-token
SIDECAR_TIMEOUT=120s

# --- Google OAuth (reserved: not yet wired) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8083/login/oauth2/code/google

# --- Railway deployment (reserved) ---
# Railway injects PORT automatically (already read above as ${PORT}).
# Set the vars above as Railway service variables; for a Railway Postgres plugin,
# point DB_URL at the plugin host or map from the provided connection string.
# PUBLIC_BASE_URL=
