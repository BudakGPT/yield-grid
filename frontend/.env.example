# Frontend (Next.js)  --  copy to .env.local. Only NEXT_PUBLIC_* vars are exposed to the browser.
NEXT_PUBLIC_API_URL=http://localhost:8083
NEXT_PUBLIC_WS_URL=ws://localhost:8083/ws
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Gates the /demo console route; anything other than "true" makes /demo a 404.
# Pair with DEMO_ENABLED=true in the backend .env, which gates /api/demo/**.
NEXT_PUBLIC_DEMO_ENABLED=false

# --- Google OAuth via Supabase ---
# Publishable/anon key (safe to expose). Matches SUPABASE_URL / SUPABASE_PUBLISHABLE_KEY in the backend .env.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
